# Google Gemini API Configuration
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Apify Configuration (Optional - for advanced scraping)
APIFY_TOKEN=your_apify_token_here

# PostgreSQL Database (Neon)
POSTGRES_URL=postgresql://username:password@host.neon.tech/database?sslmode=require

# Database Paths
FAISS_INDEX_PATH=./backend/data/faiss/index.bin
METADATA_DB_PATH=./backend/data/processed/products.db
RAW_DATA_PATH=./backend/data/raw

# Server Configuration
PORT=3001
NODE_ENV=development

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Email Configuration (Resend API - recommended for production)
# Get API key from: https://resend.com (free tier: 3000 emails/day)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev

# Legacy SMTP Configuration (fallback - not recommended for production)
# Only used if RESEND_API_KEY is not set
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="Rufus AI Shopper" <your_email@gmail.com>

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000
